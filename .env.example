# Database
DATABASE_URL=postgresql://maycast:maycast@localhost:5432/maycast
POSTGRES_USER=maycast
POSTGRES_PASSWORD=maycast
POSTGRES_DB=maycast

# MinIO / R2
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=maycast-media
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
# Browser-accessible S3 endpoint (for presigned URLs in Docker)
S3_PUBLIC_ENDPOINT=http://localhost:9000

# Public URL for media access
MEDIA_BASE_URL=http://localhost:9000/maycast-media

# Backend
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Frontend
VITE_API_URL=http://localhost:3001
